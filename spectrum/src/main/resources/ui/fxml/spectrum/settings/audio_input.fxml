<?xml version="1.0" encoding="UTF-8"?>

<?import com.lazydash.audio.visualizer.spectrum.ui.fxml.common.FxmlCounter?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lazydash.audio.visualizer.spectrum.ui.fxml.spectrum.settings.AudioInputController">

    <Label styleClass="title" text="Audio format and buffer size" />
    <Separator styleClass="separator"/>
    <GridPane styleClass="settings-group">

        <fx:define>
            <FxmlCounter fx:id="row" />
        </fx:define>

        <Label text="Input device: " GridPane.rowIndex="$row.increment" GridPane.columnIndex="0"/>
        <ComboBox fx:id="inputDevice" onAction="#updateInputDevice" GridPane.rowIndex="$row.value" GridPane.columnIndex="1"/>

        <Label text="Output device: " GridPane.rowIndex="$row.increment" GridPane.columnIndex="0"/>
        <ComboBox fx:id="outputDevice" onAction="#updateOutputDevice" GridPane.rowIndex="$row.value" GridPane.columnIndex="1"/>

        <Label text="FFT Window Size (ms):" GridPane.rowIndex="$row.increment" GridPane.columnIndex="0"/>
        <Spinner fx:id="fftWindowMs" editable="true" GridPane.rowIndex="$row.value" GridPane.columnIndex="1">
            <valueFactory>
                <SpinnerValueFactory.IntegerSpinnerValueFactory min="16" max="1000" amountToStepBy="256"/>
            </valueFactory>
        </Spinner>

        <Label text="FFT Window Frames:" GridPane.rowIndex="$row.increment" GridPane.columnIndex="0"/>
        <Spinner fx:id="fftWindowFrames" editable="true" GridPane.rowIndex="$row.value" GridPane.columnIndex="1">
            <valueFactory>
                <SpinnerValueFactory.IntegerSpinnerValueFactory min="0" max="100" amountToStepBy="256"/>
            </valueFactory>
        </Spinner>

    </GridPane>

</VBox>
